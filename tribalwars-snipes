        #kliny-army-btn:hover    { background: #1f6e3b; }
        #kliny-settings-btn { background: #555; color: #fff; }
        #kliny-settings-btn:hover { background: #333; }
        #kliny-count { font-size:12px; color:#888; }

        /* ── Confirmation modal ── */
        #kliny-confirm-modal {
            position: fixed; inset: 0;
            background: rgba(0,0,0,0.65);
            z-index: 999998;
            display: flex; align-items: center; justify-content: center;
        }
        #kliny-modal-box {
            background: #1e1e1e; color: #ddd;
            border: 1px solid #555; border-radius: 8px;
            padding: 20px 24px; width: 460px; max-width: 95vw;
