    // ── Memo page: fetch attacked players for tribe picker ─────────────────────
    function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

    function fetchAttackedPlayers(callback) {
        GM_xmlhttpRequest({
            method: 'GET',
            url: `${API_BASE}/api/v1/attacked_players?world=${encodeURIComponent(world)}`,
            headers: { 'Authorization': `Bearer ${API_KEY}` },
            onload(resp) {
                try {
                    const json = JSON.parse(resp.responseText);
                    callback(json.players || []);
                } catch { callback([]); }
            },
            onerror() { callback([]); },
        });
    }

    // ── Memo page: show results modal ─────────────────────────────────────────
    // ── Memo page: auto-write notes into TW note tabs ────────────────────────
    // TW notes UI (screen=memo):
    //   1. Click "+" → new tab created and selected
    //   2. Click "Editar" (locale-dependent) → textarea appears
    //   3. Fill textarea
    //   4. Click "Guardar" / "Zapisz" / "Save" etc.
    async function writeSingleNote(content) {
        // Step 1 – click "+" and wait for Memo.selectedTab to update
        const addBtn = document.querySelector('#memo-add-tab-button a');
        if (!addBtn) return 'Could not find the "+" button (#memo-add-tab-button a)';

        const oldTabId = (typeof Memo !== 'undefined') ? Memo.selectedTab : null;
        addBtn.click();

        // Poll up to 2 s for the new tab to be registered
        let elapsed = 0;
        while (elapsed < 2000) {
            await sleep(100);
            elapsed += 100;
            if (typeof Memo !== 'undefined' && Memo.selectedTab && Memo.selectedTab !== oldTabId) break;
        }
        const tabId = (typeof Memo !== 'undefined') ? Memo.selectedTab : null;
        if (!tabId || tabId === oldTabId) return 'Timed out waiting for new tab to be created';

        // Step 2 – click Edit link (CSS class a.edit_link — locale-agnostic)
        const editLink = document.querySelector('#memo_' + tabId + ' a.edit_link');
        if (!editLink) return 'Could not find a.edit_link for tab ' + tabId;
        editLink.click();
        await sleep(700);

        // Step 3 – fill textarea (identified by TW's own id="message_TABID")
        const ta = document.getElementById('message_' + tabId);
        if (!ta) return 'Could not find #message_' + tabId + ' textarea';
        ta.value = content;
        ta.dispatchEvent(new Event('input',  { bubbles: true }));
        ta.dispatchEvent(new Event('change', { bubbles: true }));

        // Step 4 – click Save (TW's own id="submit_memo_TABID")
        const saveBtn = document.getElementById('submit_memo_' + tabId);
        if (!saveBtn) return 'Could not find #submit_memo_' + tabId;
        saveBtn.click();
        await sleep(500);

        return null; // null = success
    }

    async function writeNotesToMemo(notes, statusEl) {
        for (let i = 0; i < notes.length; i++) {
            statusEl.style.color = '#aaa';
            statusEl.textContent = `Writing note ${i + 1} of ${notes.length} to TW…`;
            const err = await writeSingleNote(notes[i]);
            if (err) {
                statusEl.style.color = '#f66';
                statusEl.textContent = `Note ${i + 1} failed: ${err}`;
                return;
            }
            await sleep(300);
        }
        statusEl.style.color = '#2a7';
        statusEl.textContent = `✓ ${notes.length} note(s) written to TW`;
    }

    function snipesToCsv(snipes) {
        if (!snipes || !snipes.length) return '';
        const headers = Object.keys(snipes[0]);
        const rows = snipes.map(r => headers.map(h => {
            const v = r[h] == null ? '' : String(r[h]);
            return v.includes(';') || v.includes('"') ? `"${v.replace(/"/g, '""')}"` : v;
        }).join(';'));
        return [headers.join(';'), ...rows].join('\r\n');
    }

    function showSnipeResults(data) {
        const existing = document.getElementById('kliny-results-modal');
        if (existing) existing.remove();

        const ts = new Date().toISOString().replace(/[-:T]/g, '').slice(0, 15);
        const suffix = data.own_snipes === false ? 'snipes_colleague' : 'snipes';
        const csvFilename = `${ts}_${data.world}_${suffix}.csv`;
        const csvContent = snipesToCsv(data.snipes || []);
        const csvHref = csvContent
            ? URL.createObjectURL(new Blob([csvContent], { type: 'text/csv' }))
            : null;

        const notesHtml = (data.notes || []).map((note, i) => `
            <div>
                <div style="color:#888;font-size:11px;margin-bottom:3px">Part ${i + 1} of ${data.notes.length}:</div>
                <div class="kliny-note-block" id="kliny-note-${i}">${escapeHtml(note)}</div>
                <button type="button" class="kliny-copy-btn" data-idx="${i}">📋 Copy</button>
            </div>
        `).join('');

        const overlay = document.createElement('div');
        overlay.id = 'kliny-results-modal';
        overlay.innerHTML = `
            <div id="kliny-results-box">
                <h3>✓ ${escapeHtml(String(data.count))} snipes generated for ${escapeHtml(data.world)}</h3>
                ${csvHref ? `<div style="margin-bottom:10px"><a id="kliny-csv-dl" href="${csvHref}" download="${escapeHtml(csvFilename)}" style="color:#ffe478;font-weight:bold">💾 Download CSV (${escapeHtml(csvFilename)})</a></div>` : ''}
                ${notesHtml || '<p style="color:#888">No notes output.</p>'}
                <button type="button" id="kliny-results-close">Close</button>
            </div>
        `;
        document.body.appendChild(overlay);

        overlay.querySelectorAll('.kliny-copy-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const idx = btn.dataset.idx;
                const text = document.getElementById(`kliny-note-${idx}`).textContent;
                navigator.clipboard.writeText(text).then(() => {
                    btn.textContent = '✓ Copied!';
                    btn.classList.add('copied');
                    setTimeout(() => { btn.textContent = '\uD83D\uDCCB Copy'; btn.classList.remove('copied'); }, 2000);
                });
            });
        });

        document.getElementById('kliny-results-close').addEventListener('click', () => {
            if (csvHref) URL.revokeObjectURL(csvHref);
            overlay.remove();
        });
        overlay.addEventListener('click', e => { if (e.target === overlay) { if (csvHref) URL.revokeObjectURL(csvHref); overlay.remove(); } });
    }

    // ── Memo page: generate snipes ────────────────────────────────────────────
    function generateSnipes(params, statusEl, btn) {
        if (!API_KEY) { showToast('Kliny: no API key set. Click ⚙ to configure.', 'error'); return; }
        btn.disabled = true;
        btn.textContent = '⏳ Generating…';
        statusEl.textContent = 'Contacting server…';

        GM_xmlhttpRequest({
            method: 'POST',
            url: `${API_BASE}/api/v1/generate_snipes`,
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${API_KEY}`,
            },
            data: JSON.stringify(params),
            onload(resp) {
                btn.disabled = false;
                btn.textContent = '⚔ Generate Snipes';
                statusEl.style.color = '#f66';
                try {
                    const json = JSON.parse(resp.responseText);
                    if (json.success) {
                        statusEl.style.color = '#888';
                        statusEl.textContent = '';
                        // Show modal immediately so notes are visible/copyable,
                        // then auto-write each note into a new TW note tab
                        showSnipeResults(json);
                        if (json.notes && json.notes.length > 0) {
                            writeNotesToMemo(json.notes, statusEl);
                        }
                    } else {
                        const msg = apiError(resp);
                        statusEl.textContent = msg;
                        showToast(`✗ ${msg}`, 'error');
                    }
                } catch {
                    const msg = apiError(resp);
                    statusEl.textContent = msg;
                    showToast(`✗ ${msg}`, 'error');
                }
            },
            onerror() {
                btn.disabled = false;
                btn.textContent = '⚔ Generate Snipes';
                statusEl.style.color = '#f66';
                statusEl.textContent = `Could not reach ${API_BASE} — is the server running?`;
            },
        });
    }

