// ==UserScript==
// @name         Kliny Uploader
// @namespace    http://tampermonkey.net/
// @version      2.0
// @description  Upload TW attacks & army overview to a local Kliny instance
// @author       You
// @match        https://*.plemiona.pl/*
// @match        https://*.tribalwars.net/*
// @match        https://*.die-staemme.de/*
// @match        https://*.staemme.ch/*
// @match        https://*.tribalwars.nl/*
// @match        https://*.tribalwars.co.uk/*
// @match        https://*.tribalwars.us/*
// @match        https://*.tribalwars.com.pt/*
// @match        https://*.tribalwars.com.br/*
// @match        https://*.divokekmeny.cz/*
// @match        https://*.tribals.it/*
// @match        https://*.guerretribale.fr/*
// @match        https://*.guerrastribales.es/*
// @grant        GM_getValue
// @grant        GM_setValue
// @grant        GM_xmlhttpRequest
// @grant        GM_addStyle
// @connect      localhost
// @connect      127.0.0.1
// @connect      tribalwars-snipes.net
// ==/UserScript==

(function () {
    'use strict';

    // ── Page detection ────────────────────────────────────────────────────────
    // Attacks upload: game.php?...&screen=reqdef
    //   (the "request for defence" page — has a BB-code textarea with incoming attacks)
    // Army overview:  game.php?...&screen=overview_villages&mode=combined
    const params  = new URLSearchParams(location.search);
    const screen  = params.get('screen');
    const mode    = params.get('mode');

    const isReqdef    = screen === 'reqdef';
    const isCombined  = screen === 'overview_villages' && mode === 'combined';
    const isMemo      = screen === 'memo';
    if (!isReqdef && !isCombined && !isMemo) return;

    // ── Settings (persisted via Tampermonkey storage) ─────────────────────────
    let API_BASE    = GM_getValue('kliny_api_base',    'https://tribalwars-snipes.net');
    let API_KEY     = GM_getValue('kliny_api_key',     '');
    // Snipe-size overrides — sent with every attacks upload so the player
    // can customise them without touching the server web UI.
    // 0 means "use the value stored in the server DB instead".
    let SNIPE_SMALL  = GM_getValue('kliny_snipe_small',  1000);
    let SNIPE_MEDIUM = GM_getValue('kliny_snipe_medium', 2000);
    let SNIPE_LARGE  = GM_getValue('kliny_snipe_large',  5000);

    // ── Extract world from hostname (e.g. es100.tribalwars.es → "es100") ─────
    const world = location.hostname.split('.')[0];

    // ── Shared API error formatter ────────────────────────────────────────────
    // Returns a human-readable error string from a GM_xmlhttpRequest response.
    function apiError(resp) {
        if (resp.status === 401) return 'Invalid or missing API key — check ⚙ Settings';
        try {
            const json = JSON.parse(resp.responseText);
            if (json.error) return `[${resp.status}] ${json.error}`;
        } catch { /* not JSON */ }
        const preview = resp.responseText.replace(/<[^>]+>/g, '').trim().slice(0, 200);
        return `HTTP ${resp.status}${preview ? ': ' + preview : ''}`;
    }

    // ── Upload raw attacks text to API ────────────────────────────────────────
    function uploadRawText(text) {
        if (!API_KEY) {
            showToast('Kliny: no API key set. Click the ⚙ button to configure.', 'error');
            return;
        }
        GM_xmlhttpRequest({
            method: 'POST',
            url: `${API_BASE}/api/v1/upload_attacks_raw`,
            headers: {
                'Content-Type':  'application/json',
                'Authorization': `Bearer ${API_KEY}`,
            },
            data: JSON.stringify({
                world, text,
                // 0 = use server-DB defaults; non-zero overrides per-upload
                ...(SNIPE_SMALL  > 0 && { small:  SNIPE_SMALL  }),
                ...(SNIPE_MEDIUM > 0 && { medium: SNIPE_MEDIUM }),
                ...(SNIPE_LARGE  > 0 && { large:  SNIPE_LARGE  }),
            }),
            onload(resp) {
                try {
                    const json = JSON.parse(resp.responseText);
                    if (json.success) {
                        showToast(`✓ Uploaded ${json.inserted} attacks to world ${json.world}`, 'success');
                    } else {
                        showToast(`✗ ${apiError(resp)}`, 'error');
                    }
                } catch {
                    showToast(`✗ ${apiError(resp)}`, 'error');
                }
            },
            onerror() {
                showToast(`✗ Could not reach ${API_BASE} — is the server running?`, 'error');
            },
        });
    }

    // ── Settings panel ────────────────────────────────────────────────────────
    function openSettings() {
        const existing = document.getElementById('kliny-settings-panel');
        if (existing) { existing.remove(); return; }

        const panel = document.createElement('div');
        panel.id = 'kliny-settings-panel';
        panel.innerHTML = `
            <div style="font-weight:bold;margin-bottom:8px">⚙ Kliny Settings</div>
            <label style="display:block;margin-bottom:4px">API Base URL:<br>
                <input id="kliny-base-input" type="text" value="${API_BASE}"
                    style="width:260px;padding:3px;margin-top:2px" />
            </label>
            <label style="display:block;margin-bottom:8px">API Key:<br>
                <input id="kliny-key-input" type="text" value="${API_KEY}"
                    style="width:260px;padding:3px;margin-top:2px" placeholder="Paste key from Profile Settings" />
            </label>
            <div style="border-top:1px solid #444;margin:8px 0 6px"></div>
            <div style="font-size:11px;color:#888;margin-bottom:6px">
                Snipe-size overrides sent with attacks upload.<br>
                Leave <b>0</b> to use the values stored in your server account settings.
            </div>
            <div style="display:flex;gap:8px;margin-bottom:8px">
                <label style="flex:1">Small:<br>
                    <input id="kliny-small-input" type="number" min="0" value="${SNIPE_SMALL}"
                        style="width:100%;padding:3px;margin-top:2px" /></label>
                <label style="flex:1">Medium / Noble:<br>
                    <input id="kliny-medium-input" type="number" min="0" value="${SNIPE_MEDIUM}"
                        style="width:100%;padding:3px;margin-top:2px" /></label>
                <label style="flex:1">Large:<br>
                    <input id="kliny-large-input" type="number" min="0" value="${SNIPE_LARGE}"
                        style="width:100%;padding:3px;margin-top:2px" /></label>
            </div>
            <button type="button" id="kliny-save-settings"
                style="padding:4px 12px;cursor:pointer;background:#4a7;color:#fff;border:none;border-radius:3px">
                Save
            </button>
        `;
        Object.assign(panel.style, {
            position: 'fixed', top: '80px', right: '16px',
            background: '#1e1e1e', color: '#ddd',
            border: '1px solid #555', borderRadius: '6px',
            padding: '14px', zIndex: '99999', fontSize: '13px',
            boxShadow: '0 4px 12px rgba(0,0,0,0.5)',
        });
        document.body.appendChild(panel);

        document.getElementById('kliny-save-settings').addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            API_BASE     = document.getElementById('kliny-base-input').value.trim().replace(/\/$/, '');
            if (API_BASE && !/^https?:\/\//i.test(API_BASE)) API_BASE = 'https://' + API_BASE;
            API_KEY      = document.getElementById('kliny-key-input').value.trim();
            SNIPE_SMALL  = parseInt(document.getElementById('kliny-small-input').value,  10) || 0;
            SNIPE_MEDIUM = parseInt(document.getElementById('kliny-medium-input').value, 10) || 0;
            SNIPE_LARGE  = parseInt(document.getElementById('kliny-large-input').value,  10) || 0;
            GM_setValue('kliny_api_base',    API_BASE);
            GM_setValue('kliny_api_key',     API_KEY);
            GM_setValue('kliny_snipe_small',  SNIPE_SMALL);
            GM_setValue('kliny_snipe_medium', SNIPE_MEDIUM);
            GM_setValue('kliny_snipe_large',  SNIPE_LARGE);
            panel.remove();
            showToast('Settings saved', 'success');
        });
    }

    // ── Parse attacks from reqdef (screen=reqdef) BB-code textarea ────────────
    // Server-side Parser.upload_attacks() handles all the BB-code parsing,
    // so we only need to read the textarea and count preview lines here.
    function getReqdefText() {
        const textarea = document.querySelector('textarea');
        if (!textarea) {
            showToast('Kliny: could not find the request textarea.', 'error');
            return null;
        }
        const text = textarea.value || '';
        if (!text.trim()) {
            showToast('Kliny: the request textarea is empty.', 'error');
            return null;
        }
        return text;
    }

    // ── Army HTML extraction (mode=combined) ──────────────────────────────────
    // Grabs the raw outerHTML of #combined_table so the server can parse it
    // correctly, avoiding any JS-side extraction bugs.
    function getArmyRawHTML() {
        const table = document.getElementById('combined_table');
        if (!table) {
            showToast('Kliny: could not find #combined_table on this page.', 'error');
            return null;
        }
        const html = table.outerHTML;
        if (!html || html.length < 100) {
            showToast('Kliny: #combined_table appears empty.', 'error');
            return null;
        }
        return html;
    }

    // ── Upload raw army HTML to API ───────────────────────────────────────────
    function uploadRawArmy(armyHtml) {
        if (!API_KEY) {
            showToast('Kliny: no API key set. Click the ⚙ button to configure.', 'error');
            return;
        }
        GM_xmlhttpRequest({
            method:  'POST',
            url:     `${API_BASE}/api/v1/upload_army_raw`,
            headers: {
                'Content-Type':  'application/json',
                'Authorization': `Bearer ${API_KEY}`,
            },
            data: JSON.stringify({ world, army_html: armyHtml }),
            onload(resp) {
                try {
                    const json = JSON.parse(resp.responseText);
                    if (json.success) {
                        showToast(`✓ Army uploaded for ${json.world} (${json.villages} villages)`, 'success');
                    } else {
                        showToast(`✗ ${apiError(resp)}`, 'error');
                    }
                } catch {
                    showToast(`✗ ${apiError(resp)}`, 'error');
                }
            },
            onerror() {
                showToast(`✗ Could not reach ${API_BASE} — is the server running?`, 'error');
            },
        });
    }

    // ── Shared confirmation modal ─────────────────────────────────────────────
    function escapeHtml(str) {
        return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    /**
     * showConfirmModal({ title, metaItems, lastSendKey, previewLines, confirmLabel, onConfirm })
     *   metaItems   – array of raw HTML strings for the meta row
     *   lastSendKey – GM storage key for last-send timestamp
     *   previewLines – array of plain strings to show in the preview box
     */
    function showConfirmModal({ title, metaItems, lastSendKey, previewLines, confirmLabel, onConfirm }) {
        const existing = document.getElementById('kliny-confirm-modal');
        if (existing) existing.remove();

        const lastSendTs = GM_getValue(lastSendKey, null);
        const lastSendStr = lastSendTs
            ? `Last upload: <b>${new Date(lastSendTs).toLocaleString()}</b>`
            : 'No previous upload on record';

        const previewHtml = previewLines.slice(0, 5)
            .map(l => `<div class="kliny-prev-row">${escapeHtml(l)}</div>`)
            .join('');
        const moreHtml = previewLines.length > 5
            ? `<div class="kliny-prev-more">…and ${previewLines.length - 5} more rows</div>`
            : '';

        const overlay = document.createElement('div');
        overlay.id = 'kliny-confirm-modal';
        overlay.innerHTML = `
            <div id="kliny-modal-box">
                <div id="kliny-modal-title">${escapeHtml(title)}</div>
                <div id="kliny-modal-meta">
                    ${metaItems.map(i => `<span>${i}</span>`).join('')}
                </div>
                <div id="kliny-modal-last">${lastSendStr}</div>
                <div id="kliny-modal-preview">
                    <div class="kliny-prev-header">Preview:</div>
                    ${previewHtml}${moreHtml}
                </div>
                <div id="kliny-modal-buttons">
                    <button type="button" id="kliny-modal-cancel">✕ Cancel</button>
                    <button type="button" id="kliny-modal-confirm">${escapeHtml(confirmLabel)}</button>
                </div>
            </div>
        `;
        document.body.appendChild(overlay);

        document.getElementById('kliny-modal-cancel').addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); overlay.remove(); });
        overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
        document.getElementById('kliny-modal-confirm').addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            overlay.remove();
            GM_setValue(lastSendKey, Date.now());
            onConfirm();
        });
    }

    function showArmyConfirmModal(armyHtml, onConfirm) {
        // Count village rows by matching coordinates in the HTML
        const coordMatches = armyHtml.match(/\(\d{1,3}\|\d{1,3}\)/g) || [];
        const villageCount = coordMatches.length;
        showConfirmModal({
            title: '⬆ Upload Army to Kliny',
            metaItems: [
                `World: <b>${escapeHtml(world)}</b>`,
                `<b>${villageCount}</b> village(s) detected`,
                `Raw HTML — parsed server-side`,
            ],
            lastSendKey: 'kliny_army_last_send',
            previewLines: coordMatches.slice(0, 10).map(c => `Village at ${c}`),
            confirmLabel: '✓ Confirm & Upload',
            onConfirm,
        });
    }

    function showReqdefConfirmModal(text, onConfirm) {
        // Count attack lines for the meta badge, but preview the full text
        const attackLines = text.split('\n').filter(l => /\[command\]attack/.test(l));
        const previewLines = text.split('\n').filter(l => l.trim());
        showConfirmModal({
            title: '⬆ Upload Attacks to Kliny',
            metaItems: [
                `World: <b>${escapeHtml(world)}</b>`,
                `<b>${attackLines.length}</b> attack line(s) detected`,
            ],
            lastSendKey: 'kliny_attacks_last_send',
            previewLines,
            confirmLabel: '✓ Confirm & Upload',
            onConfirm,
        });
    }

    // ── Toast notification ────────────────────────────────────────────────────
    function showToast(msg, type = 'success', duration = 4000) {
        const toast = document.createElement('div');
        // Support multi-line messages
        toast.innerHTML = msg.split('\n').map(escapeHtml).join('<br>');
        Object.assign(toast.style, {
            position: 'fixed', bottom: '20px', right: '20px',
            background: type === 'success' ? '#2a7' : '#c44',
            color: '#fff', padding: '10px 18px', borderRadius: '5px',
            fontSize: '13px', zIndex: '999999', maxWidth: '380px',
            boxShadow: '0 3px 10px rgba(0,0,0,0.4)',
            transition: 'opacity 0.5s', lineHeight: '1.5',
        });
        document.body.appendChild(toast);
        setTimeout(() => { toast.style.opacity = '0'; }, duration);
        setTimeout(() => toast.remove(), duration + 700);
    }

