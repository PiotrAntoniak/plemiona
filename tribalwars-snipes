            <div id="kliny-snipe-actions">
                <button type="button" id="kliny-generate-btn">⚔ Generate Snipes</button>
                <button type="button" id="kliny-panel-settings-btn">⚙</button>
            </div>
            <div id="kliny-status"></div>
        `;
        document.body.appendChild(panel);

        const modeEl       = document.getElementById('kliny-mode');
        const playerField  = document.getElementById('kliny-player-field');
        const playersList  = document.getElementById('kliny-players-list');
        const loadingSpan  = document.getElementById('kliny-players-loading');
        const generateBtn  = document.getElementById('kliny-generate-btn');
        const statusEl     = document.getElementById('kliny-status');

        // Show/hide player picker when mode changes
        modeEl.addEventListener('change', () => {
            if (modeEl.value === 'tribe') {
                playerField.style.display = 'block';
                if (!playersList.children.length) {
                    fetchAttackedPlayers(players => {
                        loadingSpan.textContent = '';
                        if (!players.length) {
                            playersList.innerHTML = '<span style="color:#888;font-size:12px">No players found (empty DB?)</span>';
                            return;
                        }
                        playersList.innerHTML = players.map(p =>
                            `<label><input type="checkbox" value="${escapeHtml(p)}" checked> ${escapeHtml(p)}</label>`
                        ).join('');
                    });
                }
            } else {
                playerField.style.display = 'none';
            }
        });

        document.getElementById('kliny-panel-settings-btn').addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation(); openSettings();
        });

        generateBtn.addEventListener('click', (e) => {
            e.preventDefault(); e.stopPropagation();
            statusEl.style.color = '#888';

            // Persist settings
            GM_setValue('kliny_blackout',   document.getElementById('kliny-blackout').value.trim());
            GM_setValue('kliny_delta',      Number(document.getElementById('kliny-delta').value));
            GM_setValue('kliny_zast',       document.getElementById('kliny-zast').value);
            GM_setValue('kliny_player_id',  Number(document.getElementById('kliny-player-id').value));

            const mode       = modeEl.value;
            const players    = mode === 'tribe'
                ? Array.from(playersList.querySelectorAll('input[type=checkbox]:checked')).map(cb => cb.value)
                : [];

            generateSnipes({
                world,
                game_base:       location.origin,
                mode,
                players,
                black_out_hours: document.getElementById('kliny-blackout').value.trim(),
                delta:           Number(document.getElementById('kliny-delta').value),
                zast:            document.getElementById('kliny-zast').value,
                player_id:       Number(document.getElementById('kliny-player-id').value),
            }, statusEl, generateBtn);
        });
    }

    // ── Inject UI button bar ──────────────────────────────────────────────────
    function injectBar() {
        if (isMemo) {
            injectMemoPanel();
            return;
        }

        if (isReqdef) {
            const bar = document.createElement('div');
            bar.id = 'kliny-bar';
            bar.innerHTML = `
                <button type="button" id="kliny-upload-btn">⬆ Upload attacks to Kliny</button>
                <button type="button" id="kliny-settings-btn">⚙</button>
                <span id="kliny-count"></span>
            `;
            document.body.appendChild(bar);

            document.getElementById('kliny-upload-btn').addEventListener('click', (e) => {
                e.preventDefault(); e.stopPropagation();
                const text = getReqdefText();
                if (!text) return;
                showReqdefConfirmModal(text, () => uploadRawText(text));
            });

            document.getElementById('kliny-settings-btn').addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); openSettings(); });
        }

        if (isCombined) {
            const bar = document.createElement('div');
            bar.id = 'kliny-bar';
            bar.innerHTML = `
                <button type="button" id="kliny-army-btn">⬆ Upload army to Kliny</button>
                <button type="button" id="kliny-settings-btn">⚙</button>
                <span id="kliny-count"></span>
            `;
            document.body.appendChild(bar);

            document.getElementById('kliny-army-btn').addEventListener('click', (e) => {
                e.preventDefault(); e.stopPropagation();
                const armyHtml = getArmyRawHTML();
                if (!armyHtml) return;
                showArmyConfirmModal(armyHtml, () => uploadRawArmy(armyHtml));
            });

            document.getElementById('kliny-settings-btn').addEventListener('click', (e) => { e.preventDefault(); e.stopPropagation(); openSettings(); });
        }
    }

    // Wait for the page to fully render before injecting
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', injectBar);
    } else {
        injectBar();
    }

