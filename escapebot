// ==UserScript==
// @name         Bot: Escape
// @namespace    http://tampermonkey.net/
// @version      3.0
// @description  Escape bot � fill units, countdown, fire attack at exact millisecond
// @author       You
// @match        https://*.guerrastribales.es/game.php?*screen=place*
// ==/UserScript==

(function () {
    'use strict';

    const UNITS       = ['spear', 'sword', 'axe', 'spy', 'light', 'marcher', 'heavy', 'ram', 'catapult', 'snob'];
    const STORAGE_KEY = 'escape_bot';
    const UI_KEY      = 'escape_bot_ui';
    const PING_KEY    = 'escape_bot_ping';
    const PING_EXPIRY  = 3 * 60 * 1000;
    const PING_SAMPLES = 5;

    const url    = new URL(location.href);
    const mode   = url.searchParams.get('mode');
    const isConfirm = location.href.includes('try=confirm');
    const village   = url.searchParams.get('village');

    if (isConfirm) {
        handleConfirmPage();
    } else if (mode === 'command') {
        handleCommandPage();
    } else {
        showPanel();
    }

    // --- PANEL ---------------------------------------------------------------

    function showPanel() {
        if (document.getElementById('escape-bot-panel')) return;
        const saved = getSavedUI();

        const panel = document.createElement('div');
        panel.id    = 'escape-bot-panel';
        panel.style = [
            'position:fixed', 'top:60px', 'right:10px', 'z-index:9999',
            'background:#f4e4bc', 'border:2px solid #7d510a', 'padding:10px',
            'font-size:12px', 'font-family:Verdana,sans-serif',
            'min-width:240px', 'box-shadow:3px 3px 8px rgba(0,0,0,.45)'
        ].join(';');

        panel.innerHTML = `
            <b style="font-size:13px">&#9876; Escape Bot</b>
            <hr style="border-color:#7d510a">
            <table style="border-collapse:collapse;width:100%">
                <tr>
                    <td style="padding:2px 4px">Cel (koord.)</td>
                    <td><input id="esc-coord" type="text" style="width:88px" placeholder="576|538" value="${saved.coord||''}"></td>
                </tr>
                ${UNITS.map(u => `
                <tr>
                    <td style="padding:2px 4px">${u}</td>
                    <td><input id="esc-${u}" type="number" min="0" style="width:80px" value="${saved.units?.[u]||0}"></td>
                </tr>`).join('')}
                <tr><td colspan="2"><hr style="border-color:#7d510a;margin:4px 0"></td></tr>
                <tr>
                    <td style="padding:2px 4px">Data wysylki</td>
                    <td>
                        <input id="esc-date" type="text" placeholder="rrrr-mm-dd" style="width:88px" value="${saved.date||''}">
                        <div style="margin-top:3px">
                            <button id="esc-today" class="btn" style="font-size:10px">Dzis</button>
                            <button id="esc-day-" class="btn" style="font-size:10px;width:22px">-</button>
                            <button id="esc-day+" class="btn" style="font-size:10px;width:22px">+</button>
                        </div>
                    </td>
                </tr>
                <tr>
                    <td style="padding:2px 4px">Godzina</td>
                    <td><input id="esc-time" type="text" placeholder="hh:mm:ss" style="width:88px" value="${saved.time||''}"></td>
                </tr>
                <tr>
                    <td style="padding:2px 4px">Milisekundy</td>
                    <td><input id="esc-ms" type="number" min="0" max="999" style="width:60px" value="${saved.ms??0}"></td>
                </tr>
            </table>
            <button id="esc-go" style="margin-top:8px;width:100%;padding:5px;background:#7d510a;color:#fff;border:none;cursor:pointer;font-weight:bold;font-size:13px">
                UCIECZKA
            </button>
            <div id="esc-err" style="color:red;margin-top:4px;font-size:11px"></div>
        `;
        document.body.appendChild(panel);

        document.getElementById('esc-today').addEventListener('click', () => {
            const d = new Date();
            document.getElementById('esc-date').value =
                new Date(d - d.getTimezoneOffset() * 60000).toISOString().split('T')[0];
        });
        document.getElementById('esc-day-').addEventListener('click', () => shiftDate(-1));
        document.getElementById('esc-day+').addEventListener('click', () => shiftDate(+1));

        function shiftDate(delta) {
            const v = document.getElementById('esc-date').value;
            if (!v) return;
            const d = new Date(v);
            document.getElementById('esc-date').value =
                new Date(d - d.getTimezoneOffset() * 60000 + delta * 86400000).toISOString().split('T')[0];
        }

        document.getElementById('esc-go').addEventListener('click', () => {
            const coordStr = document.getElementById('esc-coord').value.trim();
            const date     = document.getElementById('esc-date').value.trim();
            const time     = document.getElementById('esc-time').value.trim();
            const ms       = document.getElementById('esc-ms').value || '0';
            const errEl    = document.getElementById('esc-err');

            if (!coordStr || !date || !time) { errEl.textContent = 'Uzupelnij koordynaty, date i godzine!'; return; }

            const [rawX, rawY] = coordStr.replace(';','|').split('|');
            const cx = (rawX||'').trim(), cy = (rawY||'').trim();
            if (!cx || !cy || isNaN(+cx) || isNaN(+cy)) { errEl.textContent = 'Format: 576|538'; return; }

            const units = {};
            UNITS.forEach(u => { const v = parseInt(document.getElementById('esc-'+u)?.value||'0'); if (v>0) units[u]=v; });
            if (!Object.keys(units).length) { errEl.textContent = 'Podaj co najmniej jedna jednostke!'; return; }

            localStorage.setItem(UI_KEY, JSON.stringify({coord:coordStr, date, time, ms, units}));
            saveConfig({cx, cy, date, time, ms, units, commandPending:true});

            location.href = 'game.php?village=' + village + '&screen=place&mode=command';
        });
    }

    // --- COMMAND PAGE --------------------------------------------------------

    function handleCommandPage() {
        const config = getConfig();
        if (!config || !config.commandPending) return;

        config.commandPending = false;
        saveConfig(config);

        setTimeout(() => {
            const xInp = document.querySelector('input[name="x"]') || document.querySelector('#place_x');
            const yInp = document.querySelector('input[name="y"]') || document.querySelector('#place_y');
            if (xInp) { xInp.value = config.cx; xInp.dispatchEvent(new Event('change', {bubbles:true})); }
            if (yInp) { yInp.value = config.cy; yInp.dispatchEvent(new Event('change', {bubbles:true})); }

            UNITS.forEach(u => {
                const inp = document.querySelector('input[name="' + u + '"]');
                if (inp && config.units[u]) { inp.value = config.units[u]; inp.dispatchEvent(new Event('change', {bubbles:true})); }
            });

            const attackBtn =
                document.querySelector('input#target_attack') ||
                document.querySelector('input[name="attack"]') ||
                Array.from(document.querySelectorAll('input[type="submit"]')).find(b => /atak|attack/i.test(b.value)) ||
                document.querySelector('input[type="submit"]');

            if (!attackBtn) { showStatus('Nie znaleziono przycisku Atak!', 'red'); return; }

            const offsetH = Math.abs(new Date().getTimezoneOffset()) / 60;
            const targetTs = new Date(
                config.date + 'T' + config.time + '.' + String(config.ms ?? 0).padStart(3,'0') + 'Z'
            ).getTime() - offsetH * 3600000;

            saveConfig({confirmPending: true});

            const statusEl = showStatus('Wysylka o: ' + config.date + ' ' + config.time + '.' + String(config.ms??0).padStart(3,'0'), '#7d510a');
            launchWorker(targetTs, attackBtn, statusEl);

        }, 600);
    }

    // --- CONFIRM PAGE --------------------------------------------------------

    function handleConfirmPage() {
        const config = getConfig();
        if (!config || !config.confirmPending) return;
        localStorage.removeItem(STORAGE_KEY);
        const btn = getConfirmButton();
        if (!btn) { showStatus('Nie znaleziono przycisku potwierdzenia!', 'red'); return; }
        setTimeout(() => btn.click(), 50);
    }

    // --- TIMING WORKER -------------------------------------------------------

    function launchWorker(targetTs, btn, statusEl) {
        const src = [
            'let w={terminated:false,ticks:0,totalDelay:0,serverTime:0,lastTick:0,ping:30,waitingForPing:false,',
            'run(data){',
            '  this.serverTime=data.serverTime; this.lastTick=this.serverTime;',
            '  const sleep=ms=>new Promise(r=>setTimeout(r,ms));',
            '  (async()=>{',
            '    while(!this.terminated){',
            '      postMessage({command:"getTime"});',
            '      const avg=this.ticks>0?this.totalDelay/this.ticks:1;',
            '      const rem=(data.target+this.ping-avg)-this.serverTime;',
            '      if(!this.waitingForPing&&rem<=20000&&rem>=15000){this.waitingForPing=true;postMessage({command:"getAveragePing"});}',
            '      if(rem<=0){this.terminated=true;postMessage({command:"fireBtn"});return;}',
            '      this.ticks++;this.totalDelay+=this.serverTime-this.lastTick;this.lastTick=this.serverTime;',
            '      await sleep(1);',
            '    }',
            '  })();',
            '}};',
            'self.onmessage=function(e){',
            '  if(e.data.command==="initialize")w.run(e.data);',
            '  else if(e.data.command==="setTime")w.serverTime=e.data.serverTime;',
            '  else if(e.data.command==="setOffset")w.ping=e.data.ping;',
            '};'
        ].join('\n');

        const worker = new Worker(URL.createObjectURL(new Blob([src], {type:'text/javascript'})));
        worker.postMessage({command:'initialize', offset:Timing.offset_to_server, target:targetTs, serverTime:Timing.getCurrentServerTime()});
        worker.onmessage = function(e) {
            switch(e.data.command) {
                case 'fireBtn':
                    btn.click();
                    worker.terminate();
                    if (statusEl) statusEl.textContent = 'Wyslano!';
                    break;
                case 'getTime':
                    worker.postMessage({command:'setTime', serverTime:Timing.getCurrentServerTime()});
                    break;
                case 'getAveragePing':
                    calcPing(worker);
                    break;
            }
        };
    }

    // --- HELPERS -------------------------------------------------------------

    function getConfirmButton() {
        if (typeof QuestArrows !== 'undefined') {
            const arrow = QuestArrows.arrows && QuestArrows.arrows[1215];
            if (arrow) {
                const map = arrow.active_nqs && arrow.active_nqs.map && arrow.active_nqs.map.find(function(e){return e.target && e.target.includes('#troop_confirm');});
                if (map) return document.querySelector(map.target);
            }
        }
        return document.querySelector('#troop_confirm_go') ||
               document.querySelector('input.btn-confirm-yes') ||
               document.querySelector('button.btn-confirm-yes');
    }

    function showStatus(msg, color) {
        const el = document.createElement('div');
        el.style = 'position:fixed;top:10px;left:50%;transform:translateX(-50%);z-index:9999;background:#f4e4bc;border:2px solid '+(color||'#7d510a')+';padding:10px 20px;font-weight:bold;font-size:14px;font-family:Verdana,sans-serif';
        el.textContent = msg;
        document.body.appendChild(el);
        return el;
    }

    function calcPing(worker) {
        if (localStorage[PING_KEY]) {
            const cache = JSON.parse(localStorage[PING_KEY]);
            if (Date.now() - cache.writeTime <= PING_EXPIRY) { worker.postMessage({command:'setOffset', ping:cache.ping}); return; }
        }
        let count=0, sum=0;
        const iv = setInterval(async function() {
            if (++count >= PING_SAMPLES) {
                const avg = sum/count;
                worker.postMessage({command:'setOffset', ping:avg});
                localStorage[PING_KEY] = JSON.stringify({writeTime:Date.now(), ping:avg});
                clearInterval(iv); return;
            }
            const start = Date.now();
            await new Promise(function(r){ const img=new Image(); img.onload=img.onerror=r; img.src='game.php?nc='+Math.random().toString(16).slice(2); });
            sum += (Date.now()-start)*0.3;
        }, 1000);
    }

    function saveConfig(cfg) { localStorage.setItem(STORAGE_KEY, JSON.stringify(cfg)); }
    function getConfig()     { try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch(e) { return null; } }
    function getSavedUI()    { try { return JSON.parse(localStorage.getItem(UI_KEY)) || {}; } catch(e) { return {}; } }

})();
